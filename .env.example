# Docker Deployment Configuration
# Copy this file to .env and customize for your deployment

# ==========================================
# Application Configuration
# ==========================================
APP_NAME="Data-Forge Analysis Platform"
APP_VERSION="1.0.0"
DEBUG=false
PORT=8000

# ==========================================
# Database Configuration
# ==========================================
# For SQLite (default):
DATABASE_URL="sqlite:///${DATA_DIR}/app.db"

# For PostgreSQL:
# DATABASE_URL="postgresql+psycopg://user:password@postgres:5432/dbname"

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"

# ==========================================
# File Storage Configuration
# ==========================================

# Data directory configuration
DATA_DIR=/app/data
DEFAULT_NAMESPACE=default

# Upload chunk size in bytes (default: 5MB)
UPLOAD_CHUNK_SIZE=5242880

# ==========================================
# Polars Engine Resource Configuration
# ==========================================

# Maximum threads per engine (0 = auto-detect)
# Recommended: Set to 50-75% of available cores per engine
# Example: For 8-core server with 5 max engines: 1-2 threads per engine
POLARS_MAX_THREADS=0

# Memory limit per engine in MB (0 = unlimited)
# Recommended: (Total RAM - 2GB for system) / MAX_CONCURRENT_ENGINES
# Example: For 16GB RAM with 5 engines: 2048-2816 MB per engine
POLARS_MAX_MEMORY_MB=0

# Streaming chunk size (0 = auto)
POLARS_STREAMING_CHUNK_SIZE=0

# Maximum concurrent engines
# Recommended: Based on available CPU cores and memory
# Small (2 cores, 4GB): 3
# Medium (4 cores, 8GB): 5
# Large (8 cores, 16GB): 10
MAX_CONCURRENT_ENGINES=10

# ==========================================
# Worker Configuration
# ==========================================

# Number of Gunicorn/Uvicorn workers (0 = auto: 2 * cores + 1)
# Recommended:
# - Development: 1
# - Small (2 cores): 2
# - Medium (4 cores): 4
# - Large (8+ cores): 8
WORKERS=2

# Maximum connections per worker
WORKER_CONNECTIONS=1000

# ==========================================
# Engine Lifecycle Configuration
# ==========================================

# Engine idle timeout in seconds (default: 300 = 5 minutes)
# Engines will be terminated after this duration of inactivity (reset on save)
ENGINE_IDLE_TIMEOUT=300

# Engine pooling interval in seconds (default: 5 seconds)
# How often to check engine states and cleanup idle engines
ENGINE_POOLING_INTERVAL=5

# ==========================================
# Scheduler Configuration
# ==========================================

# How often to check for due schedules in seconds (default: 60)
SCHEDULER_CHECK_INTERVAL=60

# ==========================================
# Job Management Configuration
# ==========================================

# Maximum job execution time in seconds (default: 300 = 5 minutes)
# Jobs that exceed this duration will be terminated
JOB_TIMEOUT=300

# ==========================================
# Filter Configuration
# ==========================================

# Default timezone for datetime normalization (IANA name)
TIMEZONE=UTC

# Normalize datetime filter literals and columns to TIMEZONE (true/false)
NORMALIZE_TZ=false

# ==========================================
# Logging Configuration
# ==========================================

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Iceberg logging (local filesystem + SQLite catalog)
LOG_ICEBERG_PATH=/app/data/logs/iceberg
LOG_ICEBERG_FLUSH_INTERVAL_SECONDS=300
LOG_QUEUE_MAX_SIZE=2000

# Queue overflow behavior: 'block' (default) or 'drop'
# 'block' waits for queue space (can slow down requests under high load)
# 'drop' discards logs when queue is full (prevents request slowdown)
LOG_QUEUE_OVERFLOW=block

# Max body size to log in bytes (default: 1MB, 0 = unlimited)
# Prevents memory issues with large request/response bodies
LOG_MAX_BODY_SIZE=0

# ==========================================
# AI Provider Configuration
# ==========================================

# Ollama base URL (local AI inference)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI API key (leave empty to disable)
OPENAI_API_KEY=

# ==========================================
# Settings Encryption
# ==========================================

# Key for encrypting runtime settings (SMTP password) at rest
SETTINGS_ENCRYPTION_KEY=

# ==========================================
# Resource Recommendations by Server Size
# ==========================================

# Small Server (2 cores, 4GB RAM):
# WORKERS=2
# POLARS_MAX_THREADS=1
# POLARS_MAX_MEMORY_MB=1024
# MAX_CONCURRENT_ENGINES=3

# Medium Server (4 cores, 8GB RAM):
# WORKERS=4
# POLARS_MAX_THREADS=2
# POLARS_MAX_MEMORY_MB=2048
# MAX_CONCURRENT_ENGINES=5

# Large Server (8 cores, 16GB RAM):
# WORKERS=8
# POLARS_MAX_THREADS=4
# POLARS_MAX_MEMORY_MB=4096
# MAX_CONCURRENT_ENGINES=10
