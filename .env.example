# Docker Deployment Configuration
# Copy this file to .env and customize for your deployment

# ==========================================
# Application Configuration
# ==========================================
APP_NAME="Polars-FastAPI-Svelte Analysis Platform"
APP_VERSION="1.0.0"
DEBUG=false
PORT=8000

# ==========================================
# Database Configuration
# ==========================================
# For SQLite (default):
DATABASE_URL="sqlite+aiosqlite:///./database/app.db"

# For PostgreSQL:
# DATABASE_URL="postgresql+asyncpg://user:password@postgres:5432/dbname"

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ==========================================
# File Storage Configuration
# ==========================================

# Data directory paths (for Docker, use container paths)
# In Docker: /app/data/*
# For local development: ./data/*
UPLOAD_DIR=/app/data/uploads
RESULTS_DIR=/app/data/results
EXPORTS_DIR=/app/data/exports

# Maximum upload file size in bytes (default: 10GB)
MAX_UPLOAD_SIZE=10737418240

# ==========================================
# Polars Engine Resource Configuration
# ==========================================

# Maximum threads per engine (0 = auto-detect)
# Recommended: Set to 50-75% of available cores per engine
# Example: For 8-core server with 5 max engines: 1-2 threads per engine
POLARS_MAX_THREADS=0

# Memory limit per engine in MB (0 = unlimited)
# Recommended: (Total RAM - 2GB for system) / MAX_CONCURRENT_ENGINES
# Example: For 16GB RAM with 5 engines: 2048-2816 MB per engine
POLARS_MAX_MEMORY_MB=0

# Streaming chunk size (0 = auto)
POLARS_STREAMING_CHUNK_SIZE=0

# Maximum concurrent engines
# Recommended: Based on available CPU cores and memory
# Small (2 cores, 4GB): 3
# Medium (4 cores, 8GB): 5
# Large (8 cores, 16GB): 10
MAX_CONCURRENT_ENGINES=10

# ==========================================
# Worker Configuration
# ==========================================

# Number of Gunicorn/Uvicorn workers (0 = auto: 2 * cores + 1)
# Recommended:
# - Development: 1
# - Small (2 cores): 2
# - Medium (4 cores): 4
# - Large (8+ cores): 8
WORKERS=2

# Maximum connections per worker
WORKER_CONNECTIONS=1000

# Worker timeout in seconds
TIMEOUT=30

# Keep-alive timeout
KEEPALIVE=5

# Graceful shutdown timeout
GRACEFUL_TIMEOUT=10

# ==========================================
# Engine Lifecycle Configuration
# ==========================================

# Engine idle timeout (seconds before cleanup)
ENGINE_IDLE_TIMEOUT=300

# Engine cleanup check interval (seconds)
ENGINE_CLEANUP_INTERVAL=30

# Process shutdown timeout (seconds)
PROCESS_SHUTDOWN_TIMEOUT=5

# Process terminate timeout (seconds)
PROCESS_TERMINATE_TIMEOUT=2

# ==========================================
# Job Management Configuration
# ==========================================

# Maximum job execution time (seconds)
JOB_TIMEOUT=300

# Job TTL - time to keep in memory (seconds)
JOB_TTL=1800

# Maximum jobs to keep in memory
MAX_JOBS_IN_MEMORY=1000

# ==========================================
# Logging Configuration
# ==========================================

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# ==========================================
# Resource Recommendations by Server Size
# ==========================================

# Small Server (2 cores, 4GB RAM):
# WORKERS=2
# POLARS_MAX_THREADS=1
# POLARS_MAX_MEMORY_MB=1024
# MAX_CONCURRENT_ENGINES=3

# Medium Server (4 cores, 8GB RAM):
# WORKERS=4
# POLARS_MAX_THREADS=2
# POLARS_MAX_MEMORY_MB=2048
# MAX_CONCURRENT_ENGINES=5

# Large Server (8 cores, 16GB RAM):
# WORKERS=8
# POLARS_MAX_THREADS=4
# POLARS_MAX_MEMORY_MB=4096
# MAX_CONCURRENT_ENGINES=10
