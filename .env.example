# Docker / compose environment — production
# Copy to /.env when running from the repository root, then: docker compose up
#
# Topology: single port.
#   FastAPI serves the pre-built SvelteKit files from frontend/build.
#   Browser and API share the same origin, so cross-origin CORS is not required
#   for normal browser traffic.  PROD_MODE_ENABLED=true activates static serving.
#
# For local development (two separate servers) use backend/.env.example instead.
# See ENV_VARIABLES.md for the full reference.

APP_NAME="Data-Forge Analysis Platform"
APP_VERSION="1.0.0"
DEBUG=false
PROD_MODE_ENABLED=true
PORT=8000

# Same-origin: no CORS needed for regular browser traffic.
# Uncomment and set only if you have out-of-band clients on a different domain.
# CORS_ORIGINS=https://your-other-domain.example.com

DATA_DIR=/app/data
DEFAULT_NAMESPACE=default
UPLOAD_CHUNK_SIZE=5242880
UPLOAD_MAX_FILE_SIZE_BYTES=2147483648

ENGINE_IDLE_TIMEOUT=60
ENGINE_POOLING_INTERVAL=30
SCHEDULER_CHECK_INTERVAL=60
JOB_TIMEOUT=300
LOCK_TTL_SECONDS=30
LOCK_HEARTBEAT_INTERVAL_SECONDS=10
POLARS_MAX_THREADS=0
POLARS_MAX_MEMORY_MB=0
POLARS_STREAMING_CHUNK_SIZE=0
MAX_CONCURRENT_ENGINES=10
WORKERS=1
WORKER_CONNECTIONS=1000

LOG_LEVEL=info
UVICORN_ACCESS_LOG=true
TIMEZONE=UTC
NORMALIZE_TZ=false
LOG_SQLITE_PATH=/app/data/logs
LOG_SQLITE_FLUSH_INTERVAL_SECONDS=5
LOG_QUEUE_MAX_SIZE=2000
LOG_QUEUE_OVERFLOW=drop
LOG_MAX_BODY_SIZE=65536

AUTH_REQUIRED=false
DEFAULT_USER_EMAIL=default@example.com
DEFAULT_USER_PASSWORD=ChangeMe123
DEFAULT_USER_NAME="Default User"
AUTH_FRONTEND_URL=http://localhost:8000
SESSION_MAX_AGE_DAYS=30

SETTINGS_ENCRYPTION_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_TOKEN=
