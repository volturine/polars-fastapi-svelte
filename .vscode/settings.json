{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/bin/python",
  "python.envFile": "${workspaceFolder}/backend/.env",
  "python.testing.pytestArgs": ["${workspaceFolder}/backend/tests"],
  "python.testing.cwd": "${workspaceFolder}/backend/tests",
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "svelte.enable-ts-plugin": true,
  "typescript.tsdk": "packages/frontend/node_modules/typescript/lib",
  "files.associations": {
    "*.svelte": "svelte"
  },
  "eslint.workingDirectories": ["./packages/frontend"],
  "ruff.path": ["${workspaceFolder}/backend/.venv/bin/ruff"],
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/node_modules": true,
    "**/.svelte-kit": true
  },
  "python-envs.pythonProjects": [],
  "projectManager.hg.ignoredFolders": ["out", "typings", "test", ".haxelib"]
}
