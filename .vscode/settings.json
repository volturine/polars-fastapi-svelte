{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "always",
      "source.organizeImports.ruff": "always"
    }
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "svelte.enable-ts-plugin": true,
  "files.associations": {
    "*.svelte": "svelte"
  },
  "eslint.workingDirectories": ["./packages/frontend"],
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/node_modules": true,
    "**/.svelte-kit": false
  },
  "python-envs.pythonProjects": [
    {
      "workspace": "${workspaceFolder}/packages/backend",
      "envManager": "venv",
      "pythonPath": "${workspaceFolder}/packages/backend/.venv/bin/python"
    },
    {
      "workspace": "${workspaceFolder}/packages/scheduler",
      "envManager": "venv",
      "pythonPath": "${workspaceFolder}/packages/scheduler/.venv/bin/python"
    },
    {
      "workspace": "${workspaceFolder}/packages/shared",
      "envManager": "venv",
      "pythonPath": "${workspaceFolder}/packages/shared/.venv/bin/python"
    },
    {
      "workspace": "${workspaceFolder}/packages/worker-manager",
      "envManager": "venv",
      "pythonPath": "${workspaceFolder}/packages/worker-manager/.venv/bin/python"
    }
  ],
  "projectManager.hg.ignoredFolders": ["out", "typings", "test", ".haxelib"]
}
