# Application Configuration
APP_NAME="Polars-FastAPI-Svelte Analysis Platform"
APP_VERSION="1.0.0"

# Debug mode - enables verbose logging and SQL echo
DEBUG=false

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000"

# Database Configuration
# SQLite database URL (default: sqlite+aiosqlite:///./database/app.db)
DATABASE_URL="sqlite+aiosqlite:///./database/app.db"

# File Storage Configuration
# Directories for uploaded files, results, and exports (relative to project root)
UPLOAD_DIR="./data/uploads"
RESULTS_DIR="./data/results"
EXPORTS_DIR="./data/exports"

# File Upload Limits
# Maximum upload file size in bytes (default: 10GB)
MAX_UPLOAD_SIZE=10737418240

# Engine Configuration
# Engine idle timeout in seconds (default: 300 = 5 minutes)
# Engines without keepalive pings will be terminated after this duration
ENGINE_IDLE_TIMEOUT=300

# Engine cleanup interval in seconds (default: 30 seconds)
# How often to check for idle engines to clean up
ENGINE_CLEANUP_INTERVAL=30

# Job Configuration
# Job execution timeout in seconds (default: 300 = 5 minutes)
# Jobs that take longer than this will timeout
JOB_TIMEOUT=300

# Job TTL in seconds (default: 1800 = 30 minutes)
# Completed jobs will be cleaned up from memory after this duration
JOB_TTL=1800

# Maximum number of jobs to keep in memory (default: 1000)
# Oldest jobs will be evicted when this limit is reached
MAX_JOBS_IN_MEMORY=1000

# Process Management Configuration
# Process shutdown timeout in seconds (default: 5 seconds)
# Time to wait for graceful shutdown before terminating
PROCESS_SHUTDOWN_TIMEOUT=5

# Process terminate timeout in seconds (default: 2 seconds)
# Time to wait after terminate before force killing
PROCESS_TERMINATE_TIMEOUT=2
