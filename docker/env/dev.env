DF_APP_NAME="Data-Forge Analysis Platform"
DF_APP_VERSION=1.0.0
DF_API_IMAGE=polars-analysis-api:latest
DF_SCHEDULER_IMAGE=polars-analysis-scheduler:latest
DF_WORKER_IMAGE=polars-analysis-worker:latest
DF_DEBUG=true
DF_API_PORT=8000
DF_FRONTEND_PORT=3000
DF_DATA_DIR=/app/data
DF_POSTGRES_DB=dataforge
DF_POSTGRES_USER=dataforge
DF_POSTGRES_PASSWORD=dataforge
DF_DATABASE_URL=postgresql+psycopg://dataforge:dataforge@postgres:5432/dataforge
DF_DATABASE_POOL_SIZE=10
DF_DATABASE_MAX_OVERFLOW=20
DF_DATABASE_POOL_TIMEOUT=30
DF_DEFAULT_NAMESPACE=default
DF_UPLOAD_CHUNK_SIZE=5242880
DF_POLARS_MAX_THREADS=0
DF_POLARS_MAX_MEMORY_MB=0
DF_POLARS_STREAMING_CHUNK_SIZE=0
DF_MAX_CONCURRENT_ENGINES=10
DF_WORKERS=1
DF_WORKER_CONNECTIONS=1000
DF_BUILD_WORKER_MIN_PROCESSES=0
DF_BUILD_WORKER_MAX_PROCESSES=4
DF_BUILD_WORKER_IDLE_EXIT_SECONDS=10
DF_ENGINE_IDLE_TIMEOUT=300
DF_JOB_TIMEOUT=300
DF_SCHEDULER_CHECK_INTERVAL=5
DF_LOG_LEVEL=info
DF_TRUSTED_PROXY_HOPS=0
DF_AUTH_REQUIRED=false
DF_DEFAULT_USER_EMAIL=default@example.com
DF_DEFAULT_USER_PASSWORD=ChangeMe123
DF_DEFAULT_USER_NAME="Default User"
DF_SETTINGS_ENCRYPTION_KEY=test-key
DF_AUTH_FRONTEND_URL=http://localhost:3000
DF_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
