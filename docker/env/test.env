DF_BUILD_WORKER_MAX_PROCESSES=4
DF_BUILD_WORKER_IDLE_EXIT_SECONDS=5
DF_SCHEDULER_CHECK_INTERVAL=1
DF_LOG_LEVEL=warning
DF_TRUSTED_PROXY_HOPS=0
DF_AUTH_REQUIRED=true
DF_VERIFY_EMAIL_ADDRESS=false
