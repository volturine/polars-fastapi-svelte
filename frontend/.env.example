# Frontend dev-server environment — local development only
# Copy to frontend/.env, then run: just dev
#
# These variables configure the Vite dev server and its proxy.
# They have NO effect in production: in prod the Vite dev server is not
# running and FastAPI serves the pre-built static files directly.
#
# See ENV_VARIABLES.md for the full reference.

# Port for the Vite dev server.
FRONTEND_PORT=3000

# Backend connection used by the Vite proxy and direct dev websocket connections.
# These match the backend PORT set in backend/.env.
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8000

# Optional Playwright override for local e2e runs.
# PW_E2E_WORKERS=4
