{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"predev": "panda codegen && panda cssgen",
		"dev": "vite dev",
		"build": "panda cssgen && vite build",
		"preview": "vite preview",
		"prepare": "panda codegen && panda cssgen && svelte-kit sync || echo ''",
		"panda:codegen": "panda codegen",
		"panda:watch": "panda codegen --watch",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@pandacss/dev": "^1.8.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.3.0",
		"eslint": "^10.0.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.53.0",
		"svelte-check": "^4.4.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@codemirror/lang-python": "^6.2.1",
		"@tanstack/svelte-query": "^6.0.18",
		"@tanstack/table-core": "^8.21.3",
		"@types/d3": "^7.4.3",
		"codemirror": "^6.0.2",
		"d3": "^7.9.0",
		"lucide-svelte": "^0.575.0",
		"neverthrow": "^8.2.0",
		"runed": "^0.37.1"
	},
	"overrides": {
		"cookie": ">=0.7.0",
		"minimatch": ">=10.2.1"
	}
}
