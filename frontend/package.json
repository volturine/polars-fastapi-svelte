{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"predev": "svelte-kit sync && panda codegen && panda cssgen",
		"dev": "vite dev",
		"build": "panda cssgen && vite build",
		"preview": "vite preview",
		"prepare": "panda codegen && panda cssgen && svelte-kit sync || echo ''",
		"panda:codegen": "panda codegen",
		"panda:watch": "panda codegen --watch",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate:step-types": "cd .. && just generate-step-types",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report tests/playwright-report",
		"test:unit": "bun ./node_modules/vitest/vitest.mjs run",
		"test:unit:watch": "bun ./node_modules/vitest/vitest.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@pandacss/dev": "^1.9.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/dompurify": "^3.2.0",
		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"jsdom": "^29.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@codemirror/lang-python": "^6.2.1",
		"@tanstack/svelte-query": "^6.1.13",
		"@tanstack/table-core": "^8.21.3",
		"@types/d3": "^7.4.3",
		"codemirror": "^6.0.2",
		"d3": "^7.9.0",
		"dompurify": "^3.3.3",
		"lucide-svelte": "^1.0.1",
		"marked": "^17.0.5",
		"neverthrow": "^8.2.0",
		"runed": "^0.37.1"
	},
	"overrides": {
		"cookie": ">=0.7.0",
		"minimatch": ">=10.2.1"
	}
}
