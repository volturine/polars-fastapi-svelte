{
	"name": "frontend",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"predev": "svelte-kit sync && panda codegen && panda cssgen",
		"dev": "vite dev",
		"build": "svelte-kit sync && panda cssgen && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && panda codegen && panda cssgen || echo ''",
		"panda:codegen": "svelte-kit sync && panda codegen",
		"panda:watch": "panda codegen --watch",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate:build-stream-types": "cd ../.. && just generate-build-stream-types",
		"generate:step-types": "cd ../.. && just generate-step-types",
		"test:e2e": "bun run test:hybrid-e2e",
		"test:hybrid-e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report tests/playwright-report",
		"test:unit": "bun ./node_modules/vitest/vitest.mjs run",
		"test:unit:watch": "bun ./node_modules/vitest/vitest.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@pandacss/dev": "^1.10.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/dompurify": "^3.2.0",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"jsdom": "^29.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@codemirror/lang-python": "^6.2.1",
		"@tanstack/svelte-query": "^6.1.25",
		"@tanstack/table-core": "^8.21.3",
		"@types/d3": "^7.4.3",
		"codemirror": "^6.0.2",
		"d3": "^7.9.0",
		"dompurify": "^3.4.1",
		"lucide-svelte": "^1.0.1",
		"marked": "^18.0.2",
		"neverthrow": "^8.2.0",
		"runed": "^0.37.1"
	}
}
