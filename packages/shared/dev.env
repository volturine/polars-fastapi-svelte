# Backend environment — local development
# Copy to backend/.env, then run: just dev
#
# Topology: local runtime.
#   - App runtime: one supervisor process that runs API, scheduler, and dynamic build workers
#   - Frontend:    Vite dev server on FRONTEND_PORT (default 3000)
#   Vite proxies /api requests to FastAPI.  PROD_MODE_ENABLED is false so FastAPI
#   does NOT serve static files; the browser talks to the Vite dev server directly.
#
# All environment variables — including Vite dev-server settings — are defined
# here so there is a single place to configure the whole stack.
# just dev sources this file for all local runtime processes.
#
# For production, use backend/.prod.env.example instead.
# For Docker/compose, use .env.example at the repository root.
# See ENV_VARIABLES.md for the full reference.

# ==========================================
# App and HTTP
# ==========================================
APP_NAME="Data-Forge Analysis Platform"
APP_VERSION="1.0.0"
DEBUG=false
PROD_MODE_ENABLED=false
PORT=8000
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"

# ==========================================
# Frontend dev server (Vite)
# ==========================================
# Port the Vite dev server listens on.  AUTH_FRONTEND_URL below must match.
FRONTEND_PORT=3000
# Backend host/port used by the Vite proxy to reach FastAPI.
# BACKEND_HOST defaults to 127.0.0.1; BACKEND_PORT defaults to PORT above.
BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8000  # Uncomment only if the Vite proxy target differs from PORT.

# ==========================================
# Storage and uploads
# ==========================================
# Keep generated runtime data out of package directories.
DATA_DIR=../../.runtime/data

# Local development now uses PostgreSQL only.
DATABASE_URL=postgresql+psycopg://dataforge:dataforge@127.0.0.1:5432/dataforge
DISTRIBUTED_RUNTIME_ENABLED=true
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DEFAULT_NAMESPACE=default
UPLOAD_CHUNK_SIZE=5242880
UPLOAD_MAX_FILE_SIZE_BYTES=2147483648

# ==========================================
# Engine execution and scheduler
# ==========================================
SCHEDULER_CHECK_INTERVAL=60
LOCK_TTL_SECONDS=30
LOCK_HEARTBEAT_INTERVAL_SECONDS=10
POLARS_MAX_THREADS=0
POLARS_MAX_MEMORY_MB=0
POLARS_STREAMING_CHUNK_SIZE=0
MAX_CONCURRENT_ENGINES=10
WORKERS=1
WORKER_CONNECTIONS=1000
EMBEDDED_BUILD_WORKER_ENABLED=false
BUILD_WORKER_MIN_PROCESSES=0
BUILD_WORKER_MAX_PROCESSES=4
BUILD_WORKER_IDLE_EXIT_SECONDS=10

# ==========================================
# Logging and time handling
# ==========================================
LOG_LEVEL=info
UVICORN_ACCESS_LOG=true
TIMEZONE=UTC
NORMALIZE_TZ=false
LOG_CLIENT_BATCH_SIZE=20
LOG_CLIENT_FLUSH_INTERVAL_MS=5000
LOG_CLIENT_DEDUPE_WINDOW_MS=500
LOG_CLIENT_FLUSH_COOLDOWN_MS=3000

LOG_FLUSH_INTERVAL_SECONDS=5
LOG_QUEUE_MAX_SIZE=2000
LOG_QUEUE_OVERFLOW=drop
LOG_MAX_BODY_SIZE=65536
PUBLIC_IDB_DEBUG=false

# ==========================================
# AI providers
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_ORGANIZATION_ID=
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_DEFAULT_MODEL=google/flan-t5-base
HUGGINGFACE_API_BASE_URL=https://api-inference.huggingface.co

# ==========================================
# DB-seeded settings
# ==========================================
# These values seed the settings table on first startup when the DB fields are empty.
SETTINGS_ENCRYPTION_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=
OPENAI_DEFAULT_MODEL_DB=
OPENAI_ENDPOINT_URL_DB=
OPENAI_ORGANIZATION_ID_DB=
OLLAMA_ENDPOINT_URL_DB=
OLLAMA_DEFAULT_MODEL_DB=
HUGGINGFACE_DEFAULT_MODEL_DB=

# ==========================================
# Authentication and OAuth
# ==========================================
AUTH_REQUIRED=false
DEFAULT_USER_EMAIL=default@example.com
DEFAULT_USER_PASSWORD=ChangeMe123
DEFAULT_USER_NAME="Default User"
# Must match FRONTEND_PORT above.
AUTH_FRONTEND_URL=http://localhost:3000
SESSION_MAX_AGE_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
