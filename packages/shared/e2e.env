# E2E test environment — used by `just test-e2e`
# Safe, self-contained config that avoids touching production data.

ENV_FILE=e2e.env

APP_NAME="Data-Forge E2E"
APP_VERSION="0.0.0-e2e"
DEBUG=false
PORT=8001
FRONTEND_PORT=3001
VITE_BACKEND_PORT=8001
E2E_PYTHON_VERSION=3.11
E2E_TIMEOUT_SECONDS=1620
E2E_TIMEOUT_GRACE_SECONDS=30
E2E_HEARTBEAT_SECONDS=60

CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"
AUTH_FRONTEND_URL="http://localhost:3001"

DATA_DIR=/tmp/polars-fastapi-svelte-e2e
DATABASE_URL=postgresql+psycopg://dataforge:dataforge@127.0.0.1:55432/dataforge
DEFAULT_NAMESPACE=default
DATABASE_POOL_SIZE=64
DATABASE_MAX_OVERFLOW=32
DATABASE_POOL_TIMEOUT=30
BUILD_WORKER_MIN_PROCESSES=0
BUILD_WORKER_MAX_PROCESSES=2
BUILD_WORKER_IDLE_EXIT_SECONDS=10

UPLOAD_CHUNK_SIZE=5242880

POLARS_MAX_THREADS=2
POLARS_MAX_MEMORY_MB=0
POLARS_STREAMING_CHUNK_SIZE=0
MAX_CONCURRENT_ENGINES=20

WORKERS=1
WORKER_CONNECTIONS=100
EMBEDDED_BUILD_WORKER_ENABLED=false
LOG_LEVEL=warning
UVICORN_ACCESS_LOG=false
LOG_QUEUE_OVERFLOW=drop
LOG_MAX_BODY_SIZE=0

PROD_MODE_ENABLED=false

TIMEZONE=UTC
NORMALIZE_TZ=false

AUTH_REQUIRED=true
VERIFY_EMAIL_ADDRESS=false
SETTINGS_ENCRYPTION_KEY=e2e-test-key-not-for-production
DEFAULT_USER_EMAIL=default@example.com
DEFAULT_USER_PASSWORD=ChangeMe123
DEFAULT_USER_NAME="Default User"
