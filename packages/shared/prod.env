# Production backend environment example
# Used by: just prod
#
# Topology: single port.
#   FastAPI serves the pre-built SvelteKit files from packages/frontend/build.
#   There is no separate Vite dev server.  Browser and API share the same
#   origin, so CORS is not required for normal browser traffic.
#   This env keeps the single-port deployment shape while repo-level
#   orchestration starts the API, scheduler, and worker-manager packages.
#
# Before deploying:
#   1. Build the frontend:  cd packages/frontend && bun run build
#   2. Copy this file:      cp backend/.prod.env.example backend/.prod.env
#   3. Edit the values below for your server.
#   4. Start:               just prod
#
# See ENV_VARIABLES.md for the complete variable reference.

# ==========================================
# App and HTTP
# ==========================================
APP_NAME="Data-Forge Analysis Platform"
APP_VERSION="1.0.0"
DEBUG=false

# Enable static-file serving from packages/frontend/build.
# Must be true in production.
PROD_MODE_ENABLED=true

PORT=8000

# In production the browser and API share the same origin, so cross-origin
# requests are not made by normal traffic.  Only set CORS_ORIGINS if you
# have an out-of-band client (e.g. a native mobile app or separate domain).
# CORS_ORIGINS=https://your-other-domain.example.com

# ==========================================
# Storage and uploads
# ==========================================
DATA_DIR=/app/data
DEFAULT_NAMESPACE=default
UPLOAD_CHUNK_SIZE=5242880
UPLOAD_MAX_FILE_SIZE_BYTES=2147483648

# ==========================================
# Engine execution and scheduler
# ==========================================
SCHEDULER_CHECK_INTERVAL=60
LOCK_TTL_SECONDS=30
LOCK_HEARTBEAT_INTERVAL_SECONDS=10
POLARS_MAX_THREADS=0
POLARS_MAX_MEMORY_MB=0
POLARS_STREAMING_CHUNK_SIZE=0
MAX_CONCURRENT_ENGINES=10
WORKERS=4
WORKER_CONNECTIONS=1000
BUILD_WORKER_MIN_PROCESSES=0
BUILD_WORKER_MAX_PROCESSES=10
BUILD_WORKER_IDLE_EXIT_SECONDS=30

# ==========================================
# Logging and time handling
# ==========================================
LOG_LEVEL=info
UVICORN_ACCESS_LOG=true
TIMEZONE=UTC
NORMALIZE_TZ=false
LOG_FLUSH_INTERVAL_SECONDS=5
LOG_QUEUE_MAX_SIZE=2000
LOG_QUEUE_OVERFLOW=drop
LOG_MAX_BODY_SIZE=65536
# PUBLIC_IDB_DEBUG enables IndexedDB debug panels; always false in production.
PUBLIC_IDB_DEBUG=false

# Client audit-log flush settings (frontend → backend, still applies in prod).
LOG_CLIENT_BATCH_SIZE=20
LOG_CLIENT_FLUSH_INTERVAL_MS=5000
LOG_CLIENT_DEDUPE_WINDOW_MS=500
LOG_CLIENT_FLUSH_COOLDOWN_MS=3000

# ==========================================
# AI providers
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_ORGANIZATION_ID=
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_DEFAULT_MODEL=google/flan-t5-base
HUGGINGFACE_API_BASE_URL=https://api-inference.huggingface.co

# ==========================================
# DB-seeded settings
# ==========================================
DATABASE_URL=postgresql+psycopg://dataforge:dataforge@localhost:5432/dataforge
DISTRIBUTED_RUNTIME_ENABLED=true
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
SETTINGS_ENCRYPTION_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=
OPENAI_DEFAULT_MODEL_DB=
OPENAI_ENDPOINT_URL_DB=
OPENAI_ORGANIZATION_ID_DB=
OLLAMA_ENDPOINT_URL_DB=
OLLAMA_DEFAULT_MODEL_DB=
HUGGINGFACE_DEFAULT_MODEL_DB=

# ==========================================
# Authentication and OAuth
# ==========================================
AUTH_REQUIRED=false
DEFAULT_USER_EMAIL=default@example.com
DEFAULT_USER_PASSWORD=ChangeMe123
DEFAULT_USER_NAME="Default User"

# The URL users open in their browser.  Since client and API share the same
# port in production, this is simply http(s)://<your-host>:<PORT>.
AUTH_FRONTEND_URL=http://localhost:8000

SESSION_MAX_AGE_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback must match the origin above.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
